{
  "name": "@montekkundan/opendungeon",
  "version": "0.1.1",
  "description": "Terminal roguelike RPG built with OpenTUI.",
  "license": "MIT",
  "homepage": "https://github.com/Montekkundan/opendungeon#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Montekkundan/opendungeon.git"
  },
  "bugs": {
    "url": "https://github.com/Montekkundan/opendungeon/issues"
  },
  "keywords": [
    "opentui",
    "terminal",
    "roguelike",
    "rpg",
    "dungeon",
    "cli",
    "bun"
  ],
  "type": "module",
  "bin": {
    "opendungeon": "bin/opendungeon",
    "opendungeon-host": "bin/opendungeon-host"
  },
  "files": [
    "assets",
    "bin",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md",
    "supabase",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "server:dev": "bun run src/server/dev.ts",
    "headless": "bun run src/headless/cli.ts",
    "www:dev": "bun --cwd packages/www dev",
    "www:build": "bun --cwd packages/www build",
    "www:typecheck": "bun --cwd packages/www typecheck",
    "www:verify": "bun --cwd packages/www verify",
    "host": "bun run src/net/host.ts",
    "start": "bun run src/main.ts",
    "build:binary": "bun build --compile --outfile=dist/opendungeon src/main.ts",
    "changeset": "changeset",
    "version-packages": "changeset version && bun run sync-version && bun install --lockfile-only",
    "sync-version": "bun run scripts/sync-version.ts",
    "release:npm": "npm publish --access public",
    "package:release": "bun run scripts/package-release.ts",
    "package:check": "bun run check && bun test && bun pm pack --dry-run",
    "check": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@opentui/core": "^0.2.4",
    "@supabase/supabase-js": "^2.105.3",
    "hono": "^4.12.18",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.13",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.184.1",
    "typescript": "^6.0.3"
  }
}
